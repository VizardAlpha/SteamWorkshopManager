<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SteamWorkshopManager.ViewModels"
        xmlns:icons="using:Material.Icons.Avalonia"
        x:Class="SteamWorkshopManager.Views.AddSessionWindow"
        x:DataType="vm:AddSessionViewModel"
        Title="{DynamicResource AddSession}"
        Width="560"
        Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Panel>
        <Grid RowDefinitions="Auto,*,Auto" Margin="32,28,32,24">

            <!-- Hero -->
            <StackPanel Grid.Row="0" Spacing="8">
                <TextBlock Text="{DynamicResource AddSessionHeroTitle}"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{DynamicResource AddSessionHeroSubtitle}"
                           FontSize="13"
                           Foreground="{DynamicResource TextMutedBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Content -->
            <StackPanel Grid.Row="1" Spacing="16" Margin="0,24,0,0">

                <!-- AppId / URL input -->
                <StackPanel Spacing="8">
                    <TextBlock Text="{DynamicResource AppIdOrUrlLabel}"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding AppIdInput, Mode=TwoWay}"
                                 PlaceholderText="{DynamicResource AppIdOrUrlPlaceholder}"
                                 IsEnabled="{Binding !IsValidating}"
                                 Padding="12,10"
                                 Margin="0,0,8,0"
                                 FontSize="13"/>
                        <Button Grid.Column="1"
                                Command="{Binding ValidateAppIdCommand}"
                                IsEnabled="{Binding !IsValidating}"
                                MinWidth="100"
                                Padding="14,10"
                                Background="{DynamicResource SurfaceOverlayBrush}"
                                BorderBrush="{DynamicResource BorderStrongBrush}"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                CornerRadius="6"
                                Content="{DynamicResource ValidateButton}"/>
                    </Grid>
                </StackPanel>

                <!-- Validating -->
                <Border IsVisible="{Binding IsValidating}"
                        Padding="16"
                        Background="{DynamicResource SurfaceCardBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel Spacing="10">
                        <ProgressBar IsIndeterminate="True"
                                     Height="3"
                                     Background="{DynamicResource SurfaceOverlayBrush}"
                                     Foreground="{DynamicResource AccentPrimaryBrush}"/>
                        <TextBlock Text="{DynamicResource Validating}"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Success preview -->
                <Border IsVisible="{Binding IsValid}"
                        Background="{DynamicResource SurfaceCardBrush}"
                        BorderBrush="{DynamicResource FeedbackSuccessBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12"
                        ClipToBounds="True">
                    <Grid ColumnDefinitions="Auto,*,Auto">

                        <!-- Header image thumbnail -->
                        <Border Grid.Column="0"
                                Width="140" Height="66"
                                CornerRadius="6"
                                ClipToBounds="True"
                                Background="{DynamicResource SurfaceOverlayBrush}">
                            <Panel>
                                <Image Source="{Binding GameHeaderImage}" Stretch="UniformToFill"/>
                                <icons:MaterialIcon Kind="ImageOutline"
                                                    Width="24" Height="24"
                                                    Foreground="{DynamicResource TextDisabledBrush}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    IsVisible="{Binding GameHeaderImage, Converter={x:Static ObjectConverters.IsNull}}"/>
                            </Panel>
                        </Border>

                        <!-- Game info -->
                        <StackPanel Grid.Column="1"
                                    Margin="16,0,0,0"
                                    Spacing="4"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding GameName}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}">
                                    <Run Text="AppID "/>
                                    <Run Text="{Binding ValidatedAppId}"/>
                                </TextBlock>
                                <TextBlock Text="·"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextDisabledBrush}"/>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <icons:MaterialIcon Kind="CheckCircle"
                                                        Width="12" Height="12"
                                                        Foreground="{DynamicResource FeedbackSuccessBrush}"
                                                        VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource WorkshopAvailable}"
                                               FontSize="12"
                                               Foreground="{DynamicResource FeedbackSuccessBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                    </Grid>
                </Border>

                <!-- Error -->
                <Border IsVisible="{Binding HasError}"
                        Background="{DynamicResource SurfaceCardBrush}"
                        BorderBrush="{DynamicResource FeedbackDangerBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <icons:MaterialIcon Kind="AlertCircleOutline"
                                            Width="20" Height="20"
                                            Foreground="{DynamicResource FeedbackDangerBrush}"
                                            VerticalAlignment="Top"
                                            Margin="0,1,0,0"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- Actions -->
            <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,16,0,0">
                <Button Grid.Column="1"
                        Command="{Binding CancelCommand}"
                        MinWidth="100"
                        Padding="14,10"
                        Margin="0,0,10,0"
                        Background="Transparent"
                        BorderBrush="{DynamicResource BorderStrongBrush}"
                        BorderThickness="1"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        CornerRadius="6"
                        Content="{DynamicResource Cancel}"/>
                <Button Grid.Column="2"
                        Command="{Binding CreateSessionCommand}"
                        IsEnabled="{Binding IsValid}"
                        MinWidth="150"
                        Padding="14,10"
                        Background="{DynamicResource AccentPrimaryGradientBrush}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        CornerRadius="6">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <icons:MaterialIcon Kind="Plus" Width="16" Height="16"/>
                        <TextBlock Text="{DynamicResource AddSession}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

        </Grid>

        <!-- Creating overlay -->
        <Border IsVisible="{Binding IsCreating}"
                Background="#CC0E141B"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16"
                        Width="260">
                <ProgressBar IsIndeterminate="True"
                             Height="4"
                             CornerRadius="2"
                             Background="{DynamicResource SurfaceElevatedBrush}"
                             Foreground="{DynamicResource AccentPrimaryBrush}"/>
                <TextBlock Text="{DynamicResource CreatingSession}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Panel>
</Window>
