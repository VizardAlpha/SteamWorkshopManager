<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SteamWorkshopManager.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="32"
             x:Class="SteamWorkshopManager.Views.Shell.FooterView"
             x:DataType="vm:MainViewModel">

    <UserControl.Styles>
        <!-- Status dot: color driven by connection state classes -->
        <Style Selector="Border.status-dot">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.status-dot.connecting">
            <Setter Property="Background" Value="{DynamicResource FeedbackWarningBrush}"/>
        </Style>
        <Style Selector="Border.status-dot.connected">
            <Setter Property="Background" Value="{DynamicResource FeedbackSuccessBrush}"/>
        </Style>
        <Style Selector="Border.status-dot.disconnected">
            <Setter Property="Background" Value="{DynamicResource FeedbackDangerBrush}"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource SurfaceElevatedBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0"
            Padding="16,6">
        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">

            <!-- Steam connection indicator -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border Classes="status-dot"
                        Classes.connecting="{Binding IsConnecting}"
                        Classes.connected="{Binding IsConnected}"
                        Classes.disconnected="{Binding IsDisconnected}"/>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- App version (right) -->
            <TextBlock Grid.Column="2"
                       Text="{Binding AppVersionDisplay}"
                       FontSize="11"
                       Foreground="{DynamicResource TextDisabledBrush}"
                       VerticalAlignment="Center"/>

        </Grid>
    </Border>

</UserControl>
