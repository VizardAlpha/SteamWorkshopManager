<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SteamWorkshopManager.ViewModels"
             xmlns:models="using:SteamWorkshopManager.Models"
             xmlns:converters="using:SteamWorkshopManager.Converters"
             xmlns:controls="using:SteamWorkshopManager.Views.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="SteamWorkshopManager.Views.ItemEditorView"
             x:DataType="vm:ItemEditorViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Padding="24,16" Background="#171a21">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Command="{Binding CloseCommand}"
                        Classes="ghost">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="←" FontSize="16"/>
                        <TextBlock Text="{DynamicResource Back}"/>
                    </StackPanel>
                </Button>
                <TextBlock Grid.Column="1" Text="{Binding Title}"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center" Margin="24,0"
                           TextTrimming="CharacterEllipsis"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                    <Button Command="{Binding ShowDeleteDialogCommand}"
                            Classes="danger"
                            Content="{DynamicResource Delete}"/>
                    <Button Command="{Binding SaveCommand}"
                            Classes="accent"
                            Content="{DynamicResource Save}"
                            IsEnabled="{Binding !IsSaving}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}" Margin="24,16">
            <!-- Tab: Informations -->
            <TabItem Header="Informations">
                <ScrollViewer>
                    <StackPanel Spacing="24" Margin="0,20">
                        <!-- Preview image -->
                        <Border Classes="card">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{DynamicResource PreviewImage}" Classes="section-header"/>
                                <Grid ColumnDefinitions="220,*">
                                    <Border Width="220" Height="140"
                                            Background="#1e2328"
                                            CornerRadius="8" ClipToBounds="True">
                                        <Panel>
                                            <Image Source="{Binding PreviewImage}" Stretch="UniformToFill"
                                                   IsVisible="{Binding PreviewImage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        IsVisible="{Binding PreviewImage, Converter={x:Static ObjectConverters.IsNull}}"
                                                        Spacing="8">
                                                <TextBlock Text="[IMG]" FontSize="14" HorizontalAlignment="Center" Opacity="0.3"/>
                                                <TextBlock Text="{DynamicResource NoImage}" FontSize="12" Foreground="#556677"/>
                                            </StackPanel>
                                        </Panel>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center" Spacing="12">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="{Binding PreviewImagePath, TargetNullValue='No image selected'}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="#8899a6"
                                                       FontSize="12"
                                                       MaxWidth="300"/>
                                            <TextBlock Text="{Binding PreviewImageSize}"
                                                       Foreground="#8899a6"
                                                       FontSize="12"
                                                       IsVisible="{Binding PreviewImageSize, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        </StackPanel>
                                        <!-- Warning if image > 1 MB -->
                                        <Border Background="#3d2a2a" Padding="8" CornerRadius="4"
                                                BorderBrush="#c23b2e" BorderThickness="1"
                                                IsVisible="{Binding IsImageTooLarge}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="!" FontWeight="Bold" Foreground="#ff8a80" FontSize="12"/>
                                                <TextBlock Text="{DynamicResource ImageTooLarge}"
                                                           Foreground="#ff8a80" FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                        <Button Command="{Binding BrowsePreviewImageCommand}"
                                                Classes="secondary"
                                                Content="{DynamicResource ChooseImage}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Title -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="{DynamicResource Title}" Classes="section-header"/>
                            <TextBox Text="{Binding Title}" MaxLength="128"
                                     Watermark="{DynamicResource TitlePlaceholder}"/>
                        </StackPanel>

                        <!-- Description -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="{DynamicResource Description}" Classes="section-header"/>
                            <controls:BbCodeEditorControl Text="{Binding Description}"
                                                          EditorHeight="150"
                                                          Watermark="{DynamicResource DescriptionPlaceholder}"/>
                        </StackPanel>

                        <!-- Content folder -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="{DynamicResource ContentFolder}" Classes="section-header"/>
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBox Text="{Binding ContentFolderPath}" IsReadOnly="True"
                                         Watermark="{DynamicResource ContentFolderPlaceholder}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ContentFolderSize}"
                                           VerticalAlignment="Center"
                                           Foreground="#8899a6"
                                           FontSize="12"
                                           Margin="12,0,0,0"
                                           IsVisible="{Binding ContentFolderSize, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                <Button Grid.Column="2" Command="{Binding BrowseContentFolderCommand}"
                                        Classes="secondary"
                                        Content="{DynamicResource Browse}" Margin="12,0,0,0"/>
                            </Grid>
                        </StackPanel>

                        <!-- Tags -->
                        <Border Classes="card">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <TextBlock Text="{DynamicResource Tags}" Classes="section-header"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding TagsLastUpdatedText}"
                                               FontSize="11"
                                               Foreground="White"
                                               Opacity="0.5"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <Button Grid.Column="2"
                                            Command="{Binding RefreshTagsCommand}"
                                            Classes="ghost"
                                            Padding="8,4"
                                            FontSize="12"
                                            IsEnabled="{Binding !IsRefreshingTags}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="↻" FontSize="14"/>
                                            <TextBlock IsVisible="{Binding IsRefreshingTags}"
                                                       Text="{DynamicResource RefreshingTags}"/>
                                            <TextBlock IsVisible="{Binding !IsRefreshingTags}"
                                                       Text="{DynamicResource RefreshTags}"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <!-- No tags message -->
                                <TextBlock Text="{DynamicResource NoTagsForWorkshop}"
                                           IsVisible="{Binding !HasTags}"
                                           Foreground="White"
                                           Opacity="0.5"
                                           FontStyle="Italic"/>

                                <ItemsControl ItemsSource="{Binding TagCategories}"
                                              IsVisible="{Binding HasTags}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="models:TagCategory">
                                            <Expander Margin="0,0,0,8">
                                                <Expander.Header>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="White"/>
                                                </Expander.Header>
                                                <Panel Margin="8,12,0,0">
                                                    <!-- Dropdown: ComboBox (single-select) -->
                                                    <Grid IsVisible="{Binding IsDropdown}"
                                                          ColumnDefinitions="Auto,Auto">
                                                        <ComboBox ItemsSource="{Binding Tags}"
                                                                  SelectedItem="{Binding SelectedTag}"
                                                                  PlaceholderText="—"
                                                                  MinWidth="200">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate DataType="models:WorkshopTag">
                                                                    <TextBlock Text="{Binding Name}"/>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                        <Button Grid.Column="1"
                                                                Command="{Binding ClearSelectedTagCommand}"
                                                                IsVisible="{Binding SelectedTag, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                                Classes="ghost"
                                                                Padding="6,4"
                                                                Margin="4,0,0,0"
                                                                FontSize="12"
                                                                Foreground="#ff8a80">
                                                            <TextBlock Text="✕"/>
                                                        </Button>
                                                    </Grid>
                                                    <!-- Checkboxes: WrapPanel (multi-select) -->
                                                    <ItemsControl ItemsSource="{Binding Tags}"
                                                                  IsVisible="{Binding !IsDropdown}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="models:WorkshopTag">
                                                                <CheckBox Content="{Binding Name}"
                                                                          IsChecked="{Binding IsSelected}"
                                                                          Margin="0,0,20,8"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Panel>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Custom Tags -->
                                <Expander Margin="0,0,0,8" IsExpanded="True">
                                    <Expander.Header>
                                        <TextBlock Text="{DynamicResource CustomTags}" FontWeight="SemiBold" Foreground="{StaticResource SteamLightBlueBrush}"/>
                                    </Expander.Header>
                                    <StackPanel Margin="8,12,0,0" Spacing="12">
                                        <!-- Add new tag -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBox Text="{Binding NewCustomTag}"
                                                     Watermark="{DynamicResource NewTagPlaceholder}"/>
                                            <Button Grid.Column="1"
                                                    Command="{Binding AddCustomTagCommand}"
                                                    Classes="accent"
                                                    Content="{DynamicResource AddCustomTag}"
                                                    Margin="12,0,0,0"/>
                                        </Grid>
                                        <!-- Custom tags list -->
                                        <ItemsControl ItemsSource="{Binding CustomTags}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="models:WorkshopTag">
                                                    <Border Background="#2a3a4a" CornerRadius="4" Padding="8,4" Margin="0,0,8,8">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <CheckBox Content="{Binding Name}"
                                                                      IsChecked="{Binding IsSelected}"/>
                                                            <Button Command="{Binding $parent[ItemsControl].((vm:ItemEditorViewModel)DataContext).RemoveCustomTagCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    Classes="ghost"
                                                                    Padding="4,2"
                                                                    FontSize="10"
                                                                    Foreground="#ff8a80">
                                                                <TextBlock Text="✕"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <!-- Visibility -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="{DynamicResource Visibility}" Classes="section-header"/>
                            <ComboBox ItemsSource="{Binding VisibilityOptions}"
                                      SelectedItem="{Binding Visibility}"
                                      Width="250">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:VisibilityType">
                                        <TextBlock Text="{Binding Converter={x:Static converters:VisibilityTypeConverter.Instance}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab: Changelog -->
            <TabItem Header="Changelog">
                <StackPanel Spacing="12" Margin="0,20">
                    <TextBlock Text="{DynamicResource UpdateNotes}" Classes="section-header"/>
                    <controls:BbCodeEditorControl Text="{Binding NewChangelog}"
                                                      EditorHeight="200"
                                                      Watermark="{DynamicResource ChangelogPlaceholder}"/>
                    <Border Background="#2a3a4a" Padding="12" CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="i" Foreground="{StaticResource SteamLightBlueBrush}" FontSize="14" FontWeight="Bold" FontStyle="Italic"/>
                            <TextBlock Text="{DynamicResource ChangelogInfo}"
                                       FontSize="12"
                                       Foreground="#8899a6"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- Tab: Versions -->
            <TabItem Header="Versions">
                <ScrollViewer>
                    <StackPanel Spacing="20" Margin="0,20">
                        <!-- Loading -->
                        <ProgressBar IsIndeterminate="True"
                                     IsVisible="{Binding IsLoadingVersions}"
                                     Height="4"/>

                        <!-- Versioning not enabled -->
                        <Border Background="#2a3a4a" Padding="16" CornerRadius="8"
                                IsVisible="{Binding !IsVersioningEnabled}">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="i" Foreground="{StaticResource SteamLightBlueBrush}" FontSize="16" FontWeight="Bold" FontStyle="Italic"/>
                                    <TextBlock Text="{DynamicResource VersioningNotEnabled}" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                                <TextBlock Text="{DynamicResource VersioningNotEnabledHint}"
                                           TextWrapping="Wrap"
                                           Foreground="#8899a6"
                                           FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <!-- Versioning enabled content -->
                        <StackPanel Spacing="20" IsVisible="{Binding IsVersioningEnabled}">
                            <!-- Current branch info -->
                            <Border Background="#2a3a4a" Padding="12" CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{DynamicResource CurrentBranch}"
                                               Foreground="#8899a6" FontSize="13"/>
                                    <TextBlock Text="{Binding CurrentBranch}"
                                               Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                </StackPanel>
                            </Border>

                            <!-- Existing versions -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="{DynamicResource ExistingVersions}" Classes="section-header"/>
                                <TextBlock Text="{DynamicResource NoVersionsYet}"
                                           Foreground="#556677"
                                           FontSize="13"
                                           IsVisible="{Binding !ExistingVersions.Count}"/>
                                <ItemsControl ItemsSource="{Binding ExistingVersions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="models:ModVersionInfo">
                                            <Border Classes="card" Margin="0,0,0,8">
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <TextBlock Text="{Binding VersionIndex, StringFormat='#{0}'}"
                                                               Foreground="#556677" FontSize="12"
                                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding RangeDisplay}"
                                                               FontWeight="SemiBold" Foreground="White"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Next upload versioning -->
                            <Border Classes="card">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="{DynamicResource NextUploadVersioning}" Classes="section-header"/>

                                    <CheckBox Content="{DynamicResource TargetAllVersions}"
                                              IsChecked="{Binding TargetAllVersions}"/>

                                    <Grid ColumnDefinitions="*,16,*"
                                          IsEnabled="{Binding !TargetAllVersions}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{DynamicResource MinBranch}"
                                                       Foreground="#8899a6" FontSize="12"/>
                                            <ComboBox ItemsSource="{Binding AvailableBranches}"
                                                      SelectedItem="{Binding SelectedBranchMin}"
                                                      PlaceholderText="{DynamicResource AnyOlderVersion}"
                                                      HorizontalAlignment="Stretch">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate DataType="models:GameBranch">
                                                        <TextBlock Text="{Binding DisplayName}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="4">
                                            <TextBlock Text="{DynamicResource MaxBranch}"
                                                       Foreground="#8899a6" FontSize="12"/>
                                            <ComboBox ItemsSource="{Binding AvailableBranches}"
                                                      SelectedItem="{Binding SelectedBranchMax}"
                                                      PlaceholderText="{DynamicResource AnyNewerVersion}"
                                                      HorizontalAlignment="Stretch">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate DataType="models:GameBranch">
                                                        <TextBlock Text="{Binding DisplayName}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Invalid range warning -->
                                    <Border Background="#3d2a2a" Padding="8" CornerRadius="4"
                                            BorderBrush="#c23b2e" BorderThickness="1"
                                            IsVisible="{Binding IsBranchRangeInvalid}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="!" FontWeight="Bold" Foreground="#ff8a80" FontSize="12"/>
                                            <TextBlock Text="{DynamicResource InvalidBranchRange}"
                                                       Foreground="#ff8a80" FontSize="12"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Content required note -->
                                    <Border Background="#2a3a4a" Padding="8" CornerRadius="4">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="i" Foreground="{StaticResource SteamLightBlueBrush}" FontSize="12" FontWeight="Bold" FontStyle="Italic"/>
                                            <TextBlock Text="{DynamicResource VersioningContentRequired}"
                                                       Foreground="#8899a6" FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab: History -->
            <TabItem Header="{DynamicResource History}">
                <DockPanel Margin="0,20">
                    <!-- Header with action buttons -->
                    <StackPanel DockPanel.Dock="Top" Spacing="12">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                            <Button Command="{Binding LoadChangelogHistoryCommand}"
                                    Classes="secondary"
                                    Content="{DynamicResource Refresh}"/>
                            <Button Grid.Column="1" Command="{Binding OpenChangelogInBrowserCommand}"
                                    Classes="secondary"
                                    Content="{DynamicResource OpenInBrowser}"
                                    Margin="8,0,0,0"/>
                            <ProgressBar Grid.Column="3"
                                         IsIndeterminate="True"
                                         IsVisible="{Binding IsLoadingChangelogs}"
                                         Width="120"
                                         VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Download progress bar -->
                        <Border IsVisible="{Binding IsDownloading}"
                                Background="#2a3a4a" Padding="12" CornerRadius="6">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{DynamicResource Downloading}" Foreground="#8899a6" FontSize="12"/>
                                <ProgressBar Value="{Binding DownloadProgress}"
                                             Minimum="0" Maximum="1"
                                             Height="6"/>
                            </StackPanel>
                        </Border>

                        <!-- Steam auth banner -->
                        <Border IsVisible="{Binding NeedsSteamAuth}"
                                Background="#2a3a4a" Padding="16" CornerRadius="8"
                                BorderBrush="{StaticResource SteamLightBlueBrush}" BorderThickness="1">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{DynamicResource SteamAuthRequired}"
                                               Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding AuthenticateWithSteamCommand}"
                                        Classes="accent"
                                        Content="{DynamicResource SteamAuthButton}"
                                        FontSize="12"
                                        IsVisible="{Binding !IsAuthenticating}"/>
                            </Grid>
                        </Border>

                        <!-- QR code overlay -->
                        <Border IsVisible="{Binding IsAuthenticating}"
                                Background="#1e2328" Padding="24" CornerRadius="8"
                                BorderBrush="{StaticResource SteamLightBlueBrush}" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center" Spacing="16">
                                <TextBlock Text="{DynamicResource SteamAuthScanQR}"
                                           Foreground="White" FontSize="14" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <Border Background="White" Padding="8" CornerRadius="8"
                                        HorizontalAlignment="Center"
                                        IsVisible="{Binding QrCodeImage, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <Image Source="{Binding QrCodeImage}"
                                           Width="200" Height="200"
                                           RenderOptions.BitmapInterpolationMode="None"/>
                                </Border>
                                <ProgressBar IsIndeterminate="True" Width="120" HorizontalAlignment="Center"
                                             IsVisible="{Binding QrCodeImage, Converter={x:Static ObjectConverters.IsNull}}"/>
                                <Button Command="{Binding CancelAuthCommand}"
                                        Classes="secondary"
                                        Content="{DynamicResource SteamAuthCancel}"
                                        HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Empty state -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="{DynamicResource NoChangelogs}"
                               Foreground="#556677"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,40"
                               IsVisible="{Binding !ChangeLogHistory.Count}"/>

                    <!-- Changelog entries -->
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding ChangeLogHistory}" Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:ChangeLogEntry">
                                    <Border Classes="card" Margin="0,0,0,8" Padding="16">
                                        <StackPanel Spacing="8">
                                            <!-- Date + Manifest row -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <TextBlock Text="{Binding Date, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                               FontWeight="SemiBold" Foreground="White" FontSize="14"/>
                                                    <TextBlock Text="{Binding ManifestId}"
                                                               Foreground="#556677" FontSize="11"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="200"/>
                                                </StackPanel>
                                                <!-- Already downloaded badge -->
                                                <Border Grid.Column="1"
                                                        Background="#1a3a2a" Padding="8,4" CornerRadius="4"
                                                        BorderBrush="#2a6a3a" BorderThickness="1"
                                                        IsVisible="{Binding IsDownloaded}">
                                                    <TextBlock Text="{DynamicResource AlreadyDownloaded}"
                                                               Foreground="#66bb6a" FontSize="11"/>
                                                </Border>
                                            </Grid>

                                            <!-- Branch info (optional) -->
                                            <StackPanel Orientation="Horizontal" Spacing="8"
                                                        IsVisible="{Binding HasBranches}">
                                                <TextBlock Text="Branch:" Foreground="#556677" FontSize="11"/>
                                                <TextBlock Text="{Binding SnapshotGameBranchMin}" Foreground="#8899a6" FontSize="11"/>
                                                <TextBlock Text="-" Foreground="#556677" FontSize="11"/>
                                                <TextBlock Text="{Binding SnapshotGameBranchMax}" Foreground="#8899a6" FontSize="11"/>
                                            </StackPanel>

                                            <!-- Description text -->
                                            <TextBox Text="{Binding ChangeDescription, Mode=OneWay}"
                                                     IsReadOnly="True"
                                                     TextWrapping="Wrap"
                                                     MaxHeight="200"
                                                     Background="#1e2328"
                                                     Foreground="#c7d5e0"
                                                     FontSize="12"
                                                     Padding="8"
                                                     CornerRadius="4"/>

                                            <!-- Action buttons -->
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                                <Button Command="{Binding $parent[UserControl].((vm:ItemEditorViewModel)DataContext).DownloadVersionCommand}"
                                                        CommandParameter="{Binding}"
                                                        Classes="accent"
                                                        Content="{DynamicResource DownloadVersion}"
                                                        FontSize="12"
                                                        Padding="12,6"
                                                        IsVisible="{Binding !IsDownloaded}"
                                                        IsEnabled="{Binding HasManifestId}"/>
                                                <Button Command="{Binding $parent[UserControl].((vm:ItemEditorViewModel)DataContext).OpenVersionFolderCommand}"
                                                        CommandParameter="{Binding}"
                                                        Classes="secondary"
                                                        Content="{DynamicResource OpenFolder}"
                                                        FontSize="12"
                                                        Padding="12,6"
                                                        IsVisible="{Binding IsDownloaded}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- Tab: Dependencies -->
            <TabItem Header="{DynamicResource Dependencies}">
                <DockPanel Margin="0,20">
                    <!-- Add dependency zone -->
                    <StackPanel DockPanel.Dock="Top" Spacing="12">
                        <!-- Input + search button -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Text="{Binding NewDependencyInput}"
                                     Watermark="{DynamicResource DependencyInputPlaceholder}"/>
                            <Button Grid.Column="1"
                                    Command="{Binding SearchDependencyCommand}"
                                    Classes="accent"
                                    Content="{DynamicResource SearchDependency}"
                                    Margin="12,0,0,0"
                                    IsEnabled="{Binding !IsSearchingDependency}"/>
                        </Grid>

                        <!-- Search progress -->
                        <ProgressBar IsIndeterminate="True"
                                     IsVisible="{Binding IsSearchingDependency}"
                                     Height="4"/>

                        <!-- Preview card -->
                        <Border IsVisible="{Binding PreviewDependency, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Background="#2a3a4a" Padding="16" CornerRadius="8"
                                BorderBrush="{StaticResource SteamLightBlueBrush}" BorderThickness="1">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{DynamicResource ConfirmAddDependency}"
                                           Foreground="#8899a6" FontSize="12"/>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="{Binding PreviewDependency.Title}"
                                               FontWeight="SemiBold" Foreground="White" FontSize="14"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding PreviewDependency.PublishedFileId}"
                                               Foreground="#556677" FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Command="{Binding ConfirmAddDependencyCommand}"
                                            Classes="accent"
                                            Content="{DynamicResource AddDependency}"
                                            IsEnabled="{Binding !IsAddingDependency}"/>
                                    <Button Command="{Binding CancelDependencyPreviewCommand}"
                                            Classes="secondary"
                                            Content="{DynamicResource Cancel}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Error message -->
                        <Border IsVisible="{Binding DependencyError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Background="#3d2a2a" Padding="8" CornerRadius="4"
                                BorderBrush="#c23b2e" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="!" FontWeight="Bold" Foreground="#ff8a80" FontSize="12"/>
                                <TextBlock Text="{Binding DependencyError}"
                                           Foreground="#ff8a80" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- Loading bar -->
                        <ProgressBar IsIndeterminate="True"
                                     IsVisible="{Binding IsLoadingDependencies}"
                                     Height="4"/>
                    </StackPanel>

                    <!-- Empty state -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="{DynamicResource NoDependencies}"
                               Foreground="#556677"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,40"
                               IsVisible="{Binding !Dependencies.Count}"/>

                    <!-- Dependencies list -->
                    <ScrollViewer>
                        <StackPanel Spacing="24">
                            <ItemsControl ItemsSource="{Binding Dependencies}" Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="models:DependencyInfo">
                                        <Border Classes="card" Margin="0,0,0,8" Padding="16">
                                            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                                                <!-- Title + ID -->
                                                <StackPanel Spacing="4" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold" Foreground="White" FontSize="14"/>
                                                    <TextBlock Text="{Binding PublishedFileId}"
                                                               Foreground="#556677" FontSize="11"/>
                                                </StackPanel>
                                                <!-- Move up/down -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                                    <Button Command="{Binding $parent[UserControl].((vm:ItemEditorViewModel)DataContext).MoveDependencyUpCommand}"
                                                            CommandParameter="{Binding}"
                                                            Classes="ghost" Padding="6,2"
                                                            ToolTip.Tip="Move up">
                                                        <TextBlock Text="&#x25B2;" FontSize="10" Foreground="#8899a6"/>
                                                    </Button>
                                                    <Button Command="{Binding $parent[UserControl].((vm:ItemEditorViewModel)DataContext).MoveDependencyDownCommand}"
                                                            CommandParameter="{Binding}"
                                                            Classes="ghost" Padding="6,2"
                                                            ToolTip.Tip="Move down">
                                                        <TextBlock Text="&#x25BC;" FontSize="10" Foreground="#8899a6"/>
                                                    </Button>
                                                </StackPanel>
                                                <!-- Open in browser -->
                                                <Button Grid.Column="2"
                                                        Command="{Binding $parent[UserControl].((vm:ItemEditorViewModel)DataContext).OpenDependencyInBrowserCommand}"
                                                        CommandParameter="{Binding}"
                                                        Classes="ghost"
                                                        Padding="8,4"
                                                        ToolTip.Tip="{DynamicResource OpenInBrowser}">
                                                    <TextBlock Text="&#x1F310;" FontSize="14"/>
                                                </Button>
                                                <!-- Remove button / spinner -->
                                                <Panel Grid.Column="3" Margin="4,0,0,0">
                                                    <Button Command="{Binding $parent[UserControl].((vm:ItemEditorViewModel)DataContext).RemoveDependencyCommand}"
                                                            CommandParameter="{Binding}"
                                                            Classes="ghost"
                                                            Padding="8,4"
                                                            Foreground="#ff8a80"
                                                            IsVisible="{Binding !IsRemoving}">
                                                        <TextBlock Text="&#x2715;" FontSize="14"/>
                                                    </Button>
                                                    <ProgressBar IsIndeterminate="True"
                                                                 IsVisible="{Binding IsRemoving}"
                                                                 Width="24" Height="24"/>
                                                </Panel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Separator -->
                            <Border Height="1" Background="#3a4a5a" Margin="0,8"/>

                            <!-- Required Apps / DLCs section -->
                            <StackPanel Spacing="12">
                                <TextBlock Text="{DynamicResource RequiredApps}" Classes="section-header"/>

                                <!-- AppID input + search -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Text="{Binding NewAppIdInput}"
                                             Watermark="{DynamicResource AppIdPlaceholder}"/>
                                    <Button Grid.Column="1"
                                            Command="{Binding SearchAppCommand}"
                                            Classes="accent"
                                            Content="{DynamicResource SearchDependency}"
                                            Margin="12,0,0,0"
                                            IsEnabled="{Binding !IsSearchingApp}"/>
                                </Grid>

                                <!-- Search progress -->
                                <ProgressBar IsIndeterminate="True"
                                             IsVisible="{Binding IsSearchingApp}"
                                             Height="4"/>

                                <!-- App preview card -->
                                <Border IsVisible="{Binding AppPreviewInfo, Converter={x:Static ObjectConverters.IsNotNull}}"
                                        Background="#2a3a4a" Padding="16" CornerRadius="8"
                                        BorderBrush="{StaticResource SteamLightBlueBrush}" BorderThickness="1">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="{DynamicResource ConfirmAddApp}"
                                                   Foreground="#8899a6" FontSize="12"/>
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="{Binding AppPreviewInfo.DisplayName}"
                                                       FontWeight="SemiBold" Foreground="White" FontSize="14"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding AppPreviewInfo.AppId, StringFormat='AppID: {0}'}"
                                                       Foreground="#556677" FontSize="11"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Command="{Binding ConfirmAddAppCommand}"
                                                    Classes="accent"
                                                    Content="{DynamicResource AddDependency}"
                                                    IsEnabled="{Binding !IsAddingApp}"/>
                                            <Button Command="{Binding CancelAppPreviewCommand}"
                                                    Classes="secondary"
                                                    Content="{DynamicResource Cancel}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- App error message -->
                                <Border IsVisible="{Binding AddAppError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                        Background="#3d2a2a" Padding="8" CornerRadius="4"
                                        BorderBrush="#c23b2e" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="!" FontWeight="Bold" Foreground="#ff8a80" FontSize="12"/>
                                        <TextBlock Text="{Binding AddAppError}"
                                                   Foreground="#ff8a80" FontSize="12"/>
                                    </StackPanel>
                                </Border>

                                <!-- Empty state -->
                                <TextBlock Text="{DynamicResource NoAppDependencies}"
                                           Foreground="#556677"
                                           FontSize="13"
                                           IsVisible="{Binding !AppDependencies.Count}"/>

                                <!-- App dependencies list -->
                                <ItemsControl ItemsSource="{Binding AppDependencies}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="models:AppDependencyInfo">
                                            <Border Classes="card" Margin="0,0,0,8" Padding="16">
                                                <Grid ColumnDefinitions="*,Auto,Auto">
                                                    <!-- Name + AppID -->
                                                    <StackPanel Spacing="4" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontWeight="SemiBold" Foreground="White" FontSize="14"/>
                                                        <TextBlock Text="{Binding AppId, StringFormat='AppID: {0}'}"
                                                                   Foreground="#556677" FontSize="11"/>
                                                    </StackPanel>
                                                    <!-- Open in store -->
                                                    <Button Grid.Column="1"
                                                            Command="{Binding $parent[UserControl].((vm:ItemEditorViewModel)DataContext).OpenAppInStoreCommand}"
                                                            CommandParameter="{Binding}"
                                                            Classes="ghost"
                                                            Padding="8,4"
                                                            ToolTip.Tip="{DynamicResource OpenInStore}">
                                                        <TextBlock Text="&#x1F6D2;" FontSize="14"/>
                                                    </Button>
                                                    <!-- Remove button / spinner -->
                                                    <Panel Grid.Column="2" Margin="4,0,0,0">
                                                        <Button Command="{Binding $parent[UserControl].((vm:ItemEditorViewModel)DataContext).RemoveAppDependencyCommand}"
                                                                CommandParameter="{Binding}"
                                                                Classes="ghost"
                                                                Padding="8,4"
                                                                Foreground="#ff8a80"
                                                                IsVisible="{Binding !IsRemoving}">
                                                            <TextBlock Text="&#x2715;" FontSize="14"/>
                                                        </Button>
                                                        <ProgressBar IsIndeterminate="True"
                                                                     IsVisible="{Binding IsRemoving}"
                                                                     Width="24" Height="24"/>
                                                    </Panel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>
        </TabControl>

        <!-- Error message -->
        <Border Grid.Row="2"
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="#3d2a2a" Padding="16" Margin="24,0,24,16" CornerRadius="8"
                BorderBrush="#c23b2e" BorderThickness="1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="!" FontWeight="Bold" Foreground="#c23b2e" FontSize="16"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#ff8a80"/>
            </StackPanel>
        </Border>

        <!-- Delete confirmation overlay -->
        <Border Grid.RowSpan="3"
                IsVisible="{Binding ShowDeleteConfirmation}"
                Background="#CC000000">
            <Border Background="#2a2e33"
                    Padding="28" CornerRadius="12"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="400"
                    BoxShadow="{StaticResource ToastShadow}">
                <StackPanel Spacing="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{DynamicResource ConfirmDelete}"
                                   FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#8899a6" FontSize="14">
                            <Run Text="{DynamicResource DeleteConfirmMessage}"/>
                            <Run Text="{Binding Title}" FontWeight="SemiBold" Foreground="White"/>
                            <Run Text="?"/>
                        </TextBlock>
                    </StackPanel>
                    <Border Background="#3d2a2a" Padding="12" CornerRadius="6"
                            BorderBrush="#c23b2e" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="!" Foreground="#ff8a80" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="{DynamicResource DeleteWarning}"
                                       Foreground="#ff8a80" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                        <Button Command="{Binding CancelDeleteCommand}"
                                Classes="secondary"
                                Content="{DynamicResource Cancel}"
                                IsEnabled="{Binding !IsDeleting}"/>
                        <Button Command="{Binding ConfirmDeleteCommand}"
                                Classes="danger"
                                Content="{DynamicResource DeletePermanently}"
                                IsEnabled="{Binding !IsDeleting}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
