<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SteamWorkshopManager.ViewModels"
             xmlns:models="using:SteamWorkshopManager.Models"
             xmlns:icons="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="640"
             x:Class="SteamWorkshopManager.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <UserControl.Styles>
        <!-- Left nav: category buttons -->
        <Style Selector="Button.nav-item">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style Selector="Button.nav-item:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceCardBrush}"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="Button.nav-item.active">
            <Setter Property="Background" Value="{DynamicResource SurfaceOverlayBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}"/>
        </Style>
        <Style Selector="Button.nav-item.active:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceOverlayBrush}"/>
        </Style>

        <!-- Section card for content pane -->
        <Style Selector="Border.section">
            <Setter Property="Background" Value="{DynamicResource SurfaceCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="TextBlock.section-caps">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <!-- Row -->
        <Style Selector="Grid.row">
            <Setter Property="Margin" Value="16,14"/>
        </Style>
        <Style Selector="TextBlock.row-label">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.row-desc">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Language picker pill -->
        <Style Selector="ListBox.lang-picker ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="ListBox.lang-picker ListBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBox.lang-picker ListBoxItem Border.lang-card">
            <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
        </Style>
        <Style Selector="ListBox.lang-picker ListBoxItem:selected Border.lang-card">
            <Setter Property="Background" Value="#1F5B9CF6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimaryBrush}"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="240,*" Margin="24,24,24,24">

        <!-- LEFT: category nav -->
        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceCardBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,16,0">
            <StackPanel Spacing="2">
                <TextBlock Text="{DynamicResource Settings}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="8,4,0,12"/>

                <Button Classes="nav-item"
                        Classes.active="{Binding IsGeneralActive}"
                        Command="{Binding NavigateToGeneralCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <icons:MaterialIcon Kind="CogOutline" Width="16" Height="16"/>
                        <TextBlock Text="{DynamicResource SettingsGeneral}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="nav-item"
                        Classes.active="{Binding IsPrivacyActive}"
                        Command="{Binding NavigateToPrivacyCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <icons:MaterialIcon Kind="ShieldOutline" Width="16" Height="16"/>
                        <TextBlock Text="{DynamicResource SettingsPrivacy}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="nav-item"
                        Classes.active="{Binding IsDebugActive}"
                        Command="{Binding NavigateToDebugCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <icons:MaterialIcon Kind="BugOutline" Width="16" Height="16"/>
                        <TextBlock Text="{DynamicResource SettingsDebug}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="nav-item"
                        Classes.active="{Binding IsUpdatesActive}"
                        Command="{Binding NavigateToUpdatesCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <icons:MaterialIcon Kind="Update" Width="16" Height="16"/>
                        <TextBlock Text="{DynamicResource SettingsUpdates}" VerticalAlignment="Center"/>
                        <Border Background="{DynamicResource FeedbackSuccessBrush}"
                                CornerRadius="6" Padding="5,1"
                                VerticalAlignment="Center"
                                IsVisible="{Binding IsUpdateAvailable}">
                            <TextBlock Text="!"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Button>

                <Button Classes="nav-item"
                        Classes.active="{Binding IsAboutActive}"
                        Command="{Binding NavigateToAboutCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <icons:MaterialIcon Kind="InformationOutline" Width="16" Height="16"/>
                        <TextBlock Text="{DynamicResource SettingsAbout}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- RIGHT: content pane -->
        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled">
            <StackPanel MaxWidth="720" HorizontalAlignment="Stretch" Spacing="20">

                <!-- ── GENERAL ── -->
                <StackPanel Spacing="12" IsVisible="{Binding IsGeneralActive}">
                    <TextBlock Text="{DynamicResource SettingsGeneral}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <Border Classes="section">
                        <StackPanel Spacing="0">
                            <TextBlock Classes="section-caps"
                                       Text="{DynamicResource Language}"
                                       Margin="16,12,16,0"/>
                            <ListBox Classes="lang-picker"
                                     ItemsSource="{Binding AvailableLanguages}"
                                     SelectedItem="{Binding SelectedLanguage}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="12,8">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="models:LanguageInfo">
                                        <Border Classes="lang-card"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="14,10"
                                                MinWidth="110">
                                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CountryCode}"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding NativeName}"
                                                           FontSize="13"
                                                           FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── PRIVACY ── -->
                <StackPanel Spacing="12" IsVisible="{Binding IsPrivacyActive}">
                    <TextBlock Text="{DynamicResource SettingsPrivacy}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <Border Classes="section">
                        <StackPanel Spacing="0">
                            <!-- Telemetry toggle -->
                            <Grid Classes="row" ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Classes="row-label" Text="{DynamicResource EnableTelemetry}"/>
                                    <TextBlock Classes="row-desc" Text="{DynamicResource TelemetryDescription}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <Button Classes="link" Padding="0"
                                                Background="Transparent" BorderThickness="0"
                                                Command="{Binding OpenPrivacyPolicyCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                <TextBlock Text="{DynamicResource ViewPrivacyPolicy}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                                <icons:MaterialIcon Kind="OpenInNew" Width="11" Height="11"
                                                                    Foreground="{DynamicResource AccentPrimaryBrush}"
                                                                    VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="link" Padding="0"
                                                Background="Transparent" BorderThickness="0"
                                                Command="{Binding OpenStatsSiteCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                <TextBlock Text="{DynamicResource ViewLiveStats}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                                <icons:MaterialIcon Kind="ChartBar" Width="11" Height="11"
                                                                    Foreground="{DynamicResource AccentPrimaryBrush}"
                                                                    VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding IsTelemetryEnabled}"
                                              OnContent="" OffContent=""
                                              VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Separator -->
                            <Border Height="1"
                                    Background="{DynamicResource BorderSubtleBrush}"
                                    Margin="16,0"/>

                            <!-- Instance ID (pseudonymous identifier, for GDPR requests) -->
                            <Grid Classes="row" ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Classes="row-label" Text="{DynamicResource YourInstanceId}"/>
                                    <TextBlock Classes="row-desc" Text="{DynamicResource YourInstanceIdDescription}"/>
                                    <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,6"
                                            HorizontalAlignment="Left">
                                        <SelectableTextBlock Text="{Binding InstanceId}"
                                                             FontSize="12"
                                                             FontFamily="Consolas, Menlo, monospace"
                                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                                             VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding CopyInstanceIdCommand}"
                                        Background="{DynamicResource SurfaceElevatedBrush}"
                                        BorderBrush="{DynamicResource BorderStrongBrush}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        CornerRadius="6"
                                        Padding="12,8"
                                        FontSize="13"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <icons:MaterialIcon Kind="ContentCopy" Width="13" Height="13"/>
                                        <TextBlock Text="{DynamicResource Copy}"
                                                   IsVisible="{Binding !IsInstanceIdCopied}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource Copied}"
                                                   IsVisible="{Binding IsInstanceIdCopied}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource FeedbackSuccessBrush}"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── DEBUG ── -->
                <StackPanel Spacing="12" IsVisible="{Binding IsDebugActive}">
                    <TextBlock Text="{DynamicResource SettingsDebug}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <Border Classes="section">
                        <StackPanel Spacing="0">
                            <!-- Debug mode toggle + log file path -->
                            <Grid Classes="row" ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Classes="row-label" Text="{DynamicResource EnableDebugMode}"/>
                                    <TextBlock Classes="row-desc" Text="{DynamicResource DebugModeDescription}"/>
                                    <Button Classes="link" Padding="0"
                                            Background="Transparent" BorderThickness="0"
                                            HorizontalAlignment="Left"
                                            IsVisible="{Binding IsDebugModeEnabled}"
                                            Command="{Binding OpenLogFolderCommand}">
                                        <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="8,5">
                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <icons:MaterialIcon Kind="FolderOutline" Width="12" Height="12"
                                                                    Foreground="{DynamicResource TextMutedBrush}"
                                                                    VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding LogFilePath}"
                                                           FontSize="11"
                                                           FontFamily="Consolas, Menlo, monospace"
                                                           Foreground="{DynamicResource AccentPrimaryBrush}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="540"/>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding IsDebugModeEnabled}"
                                              OnContent="" OffContent=""
                                              VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Separator -->
                            <Border Height="1"
                                    Background="{DynamicResource BorderSubtleBrush}"
                                    Margin="16,0"/>

                            <!-- App data folder -->
                            <Grid Classes="row" ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Classes="row-label" Text="{DynamicResource AppDataFolder}"/>
                                    <TextBlock Classes="row-desc" Text="{DynamicResource AppDataFolderDescription}"/>
                                    <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8,5"
                                            HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <icons:MaterialIcon Kind="FolderOutline" Width="12" Height="12"
                                                                Foreground="{DynamicResource TextMutedBrush}"
                                                                VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding DataFolderPath}"
                                                       FontSize="11"
                                                       FontFamily="Consolas, Menlo, monospace"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="540"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding OpenDataFolderCommand}"
                                        Background="{DynamicResource SurfaceElevatedBrush}"
                                        BorderBrush="{DynamicResource BorderStrongBrush}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        CornerRadius="6"
                                        Padding="12,8"
                                        FontSize="13"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <icons:MaterialIcon Kind="FolderOpenOutline" Width="14" Height="14"/>
                                        <TextBlock Text="{DynamicResource OpenFolder}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Separator -->
                            <Border Height="1"
                                    Background="{DynamicResource BorderSubtleBrush}"
                                    Margin="16,0"/>

                            <!-- Log folder size + Clear logs -->
                            <Grid Classes="row" ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Classes="row-label" Text="{DynamicResource LogFolderSize}"/>
                                    <TextBlock Classes="row-desc" Text="{DynamicResource LogFolderSizeDescription}"/>
                                    <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8,5"
                                            HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <icons:MaterialIcon Kind="DatabaseOutline" Width="12" Height="12"
                                                                Foreground="{DynamicResource TextMutedBrush}"
                                                                VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding LogFolderSizeDisplay}"
                                                       FontSize="11"
                                                       FontFamily="Consolas, Menlo, monospace"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding ClearLogsCommand}"
                                        Background="{DynamicResource SurfaceElevatedBrush}"
                                        BorderBrush="{DynamicResource BorderStrongBrush}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        CornerRadius="6"
                                        Padding="12,8"
                                        FontSize="13"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <icons:MaterialIcon Kind="DeleteOutline" Width="14" Height="14"/>
                                        <TextBlock Text="{DynamicResource ClearLogs}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── UPDATES ── -->
                <StackPanel Spacing="12" IsVisible="{Binding IsUpdatesActive}">
                    <TextBlock Text="{DynamicResource SettingsUpdates}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <Border Classes="section">
                        <StackPanel Spacing="0">
                            <!-- Current version row -->
                            <Grid Classes="row" ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Classes="row-label" Text="{DynamicResource CurrentVersion}"/>
                                    <TextBlock Classes="row-desc" Text="{Binding AppVersion, StringFormat='v{0}'}"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding CheckForUpdatesCommand}"
                                        IsEnabled="{Binding !IsCheckingUpdates}"
                                        Background="{DynamicResource SurfaceElevatedBrush}"
                                        BorderBrush="{DynamicResource BorderStrongBrush}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        CornerRadius="6"
                                        Padding="14,8"
                                        FontSize="13"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <icons:MaterialIcon Kind="Refresh" Width="13" Height="13"/>
                                        <TextBlock Text="{DynamicResource CheckForUpdates}"
                                                   IsVisible="{Binding !IsCheckingUpdates}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource CheckingUpdates}"
                                                   IsVisible="{Binding IsCheckingUpdates}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Up to date banner -->
                            <Border IsVisible="{Binding !IsUpdateAvailable}"
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="16,12">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <icons:MaterialIcon Kind="CheckCircleOutline" Width="16" Height="16"
                                                        Foreground="{DynamicResource FeedbackSuccessBrush}"
                                                        VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource UpToDate}"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- New version banner -->
                            <Border IsVisible="{Binding IsUpdateAvailable}"
                                    Background="#1F5EC384"
                                    BorderBrush="{DynamicResource FeedbackSuccessBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="16,14">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <icons:MaterialIcon Kind="RocketLaunchOutline" Width="16" Height="16"
                                                                Foreground="{DynamicResource FeedbackSuccessBrush}"
                                                                VerticalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource NewVersionAvailable}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding UpdateInfo.LatestVersion}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Command="{Binding OpenReleasePageCommand}"
                                            Background="{DynamicResource AccentPrimaryGradientBrush}"
                                            Foreground="White"
                                            FontWeight="SemiBold"
                                            BorderThickness="0"
                                            CornerRadius="6"
                                            Padding="14,8"
                                            VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <icons:MaterialIcon Kind="Download" Width="13" Height="13"/>
                                            <TextBlock Text="{DynamicResource Download}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── ABOUT ── -->
                <StackPanel Spacing="12" IsVisible="{Binding IsAboutActive}">
                    <TextBlock Text="{DynamicResource SettingsAbout}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <Border Classes="section">
                        <StackPanel Spacing="12" Margin="18,16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Steam Workshop Manager"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button Command="{Binding OpenGitHubCommand}"
                                        Background="{DynamicResource SurfaceElevatedBrush}"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        CornerRadius="6"
                                        Padding="12,8"
                                        FontSize="13">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <icons:MaterialIcon Kind="Github" Width="14" Height="14"/>
                                        <TextBlock Text="{DynamicResource OpenGitHub}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding OpenChangelogCommand}"
                                        Background="{DynamicResource SurfaceElevatedBrush}"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        CornerRadius="6"
                                        Padding="12,8"
                                        FontSize="13">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <icons:MaterialIcon Kind="FileDocumentOutline" Width="14" Height="14"/>
                                        <TextBlock Text="{DynamicResource OpenChangelog}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>