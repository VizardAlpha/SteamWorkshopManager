<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SteamWorkshopManager.ViewModels"
             xmlns:models="using:SteamWorkshopManager.Models"
             xmlns:icons="using:Material.Icons.Avalonia"
             xmlns:enums="using:SteamWorkshopManager.Models"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="640"
             x:Class="SteamWorkshopManager.Views.ItemListView"
             x:DataType="vm:ItemListViewModel">

    <UserControl.Styles>
        <!-- Search bar container -->
        <Style Selector="Border.search-bar">
            <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Width" Value="300"/>
        </Style>
        <!-- Inner TextBox: no border, no focus adorner, placeholder vertically centered -->
        <Style Selector="Border.search-bar TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusAdorner" Value="{x:Null}"/>
        </Style>
        <Style Selector="Border.search-bar TextBox /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Border.search-bar TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Border.search-bar TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Border.search-bar TextBox:focus-within /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

        <!-- Action button ghost-style -->
        <Style Selector="Button.action">
            <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.action:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
        </Style>

        <!-- Mod card -->
        <Style Selector="Button.mod-card">
            <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.mod-card:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceCardBrush}"/>
            <Setter Property="BorderBrush" Value="#5B9CF6"/>
        </Style>
        <!-- Selected state — strong accent border so the user can scan picks
             at a glance without checking every checkbox individually. -->
        <Style Selector="Button.mod-card.selected /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="#5B9CF6"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <!-- Selection check overlay shown only in selection mode -->
        <Style Selector="Border.select-check">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#CC101418"/>
            <Setter Property="BorderBrush" Value="#80FFFFFF"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="8,8,0,0"/>
        </Style>
        <Style Selector="Border.select-check.checked">
            <Setter Property="Background" Value="#5B9CF6"/>
            <Setter Property="BorderBrush" Value="#5B9CF6"/>
        </Style>

        <!-- Visibility badge (top-right overlay on thumb).
             Stronger bg opacity + drop shadow so it stays legible on bright
             Steam header images (orange/red cover art), not just dark thumbs. -->
        <Style Selector="Border.vis-badge">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BoxShadow" Value="0 2 6 0 #99000000"/>
        </Style>
        <Style Selector="Border.vis-badge.public">
            <Setter Property="Background" Value="#CC0F3A22"/>
            <Setter Property="BorderBrush" Value="#CC3DBA76"/>
        </Style>
        <Style Selector="Border.vis-badge.public TextBlock">
            <Setter Property="Foreground" Value="#5BDB92"/>
        </Style>
        <Style Selector="Border.vis-badge.public icons|MaterialIcon">
            <Setter Property="Foreground" Value="#5BDB92"/>
        </Style>
        <Style Selector="Border.vis-badge.friends">
            <Setter Property="Background" Value="#CC122647"/>
            <Setter Property="BorderBrush" Value="#CC5B9CF6"/>
        </Style>
        <Style Selector="Border.vis-badge.friends TextBlock">
            <Setter Property="Foreground" Value="#7FB3FA"/>
        </Style>
        <Style Selector="Border.vis-badge.friends icons|MaterialIcon">
            <Setter Property="Foreground" Value="#7FB3FA"/>
        </Style>
        <Style Selector="Border.vis-badge.private">
            <Setter Property="Background" Value="#CC3A1414"/>
            <Setter Property="BorderBrush" Value="#CCE04A4A"/>
        </Style>
        <Style Selector="Border.vis-badge.private TextBlock">
            <Setter Property="Foreground" Value="#F36E6E"/>
        </Style>
        <Style Selector="Border.vis-badge.private icons|MaterialIcon">
            <Setter Property="Foreground" Value="#F36E6E"/>
        </Style>
        <Style Selector="Border.vis-badge.unlisted">
            <Setter Property="Background" Value="#CC3A2D0D"/>
            <Setter Property="BorderBrush" Value="#CCC8A43C"/>
        </Style>
        <Style Selector="Border.vis-badge.unlisted TextBlock">
            <Setter Property="Foreground" Value="#E5BE5A"/>
        </Style>
        <Style Selector="Border.vis-badge.unlisted icons|MaterialIcon">
            <Setter Property="Foreground" Value="#E5BE5A"/>
        </Style>

        <!-- Contributor badge — shown when IsOwner is false. -->
        <Style Selector="Border.contributor-badge">
            <Setter Property="Background" Value="#CC2A1A5C"/>
            <Setter Property="BorderBrush" Value="#CC8B5CF6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BoxShadow" Value="0 2 6 0 #99000000"/>
        </Style>
        <Style Selector="Border.contributor-badge icons|MaterialIcon">
            <Setter Property="Foreground" Value="#B89CFA"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- Page header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="32,28,32,24" VerticalAlignment="Top">

            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{DynamicResource MyPublicationsTitle}"
                           FontSize="20"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{DynamicResource MyPublicationsSubtitle}"
                           FontSize="13"
                           Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <!-- Search bar — kept visible in selection mode so the user can
                     filter the grid before picking. -->
                <Border Classes="search-bar">
                    <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                        <icons:MaterialIcon Grid.Column="0"
                                            Kind="Magnify"
                                            Width="14" Height="14"
                                            Foreground="{DynamicResource TextMutedBrush}"
                                            VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchQuery, Mode=TwoWay}"
                                 PlaceholderText="{DynamicResource SearchMods}"
                                 VerticalAlignment="Center"/>
                        <!-- Clear button — visible only when something is typed -->
                        <Button Grid.Column="2"
                                Classes="search-clear"
                                Command="{Binding ClearSearchCommand}"
                                IsVisible="{Binding SearchQuery, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Width="22" Height="22"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                VerticalAlignment="Center"
                                ToolTip.Tip="{DynamicResource ClearSearch}">
                            <icons:MaterialIcon Kind="CloseCircle"
                                                Width="14" Height="14"
                                                Foreground="{DynamicResource TextMutedBrush}"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Normal-mode actions -->
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                            IsVisible="{Binding IsNotInSelectionMode}">
                    <Button Classes="action"
                            Command="{Binding LoadItemsCommand}"
                            IsEnabled="{Binding !IsLoading}">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <icons:MaterialIcon Kind="Refresh" Width="14" Height="14"/>
                            <TextBlock Text="{DynamicResource Refresh}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="action"
                            Command="{Binding EnterSelectionModeCommand}"
                            IsEnabled="{Binding !IsLoading}">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <icons:MaterialIcon Kind="CheckboxMultipleOutline" Width="14" Height="14"/>
                            <TextBlock Text="{DynamicResource Select}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Selection-mode actions -->
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                            IsVisible="{Binding SelectionMode}">
                    <TextBlock Text="{Binding SelectedCount, StringFormat={}{0} selected}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <Button Classes="action"
                            Command="{Binding SelectAllCommand}"
                            Content="{DynamicResource SelectAll}"/>
                    <Button Classes="action"
                            Command="{Binding ClearSelectionCommand}"
                            IsEnabled="{Binding HasSelection}"
                            Content="{DynamicResource ClearSelection}"/>
                    <!-- Visibility split via a flyout — one button per option keeps
                         the click count to two and avoids nesting a ComboBox here. -->
                    <Button Classes="action" IsEnabled="{Binding HasSelection}">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <icons:MaterialIcon Kind="Eye" Width="14" Height="14"/>
                            <TextBlock Text="{DynamicResource ChangeVisibility}" VerticalAlignment="Center"/>
                            <icons:MaterialIcon Kind="ChevronDown" Width="12" Height="12"/>
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="{DynamicResource Public}"
                                          Command="{Binding SetSelectedVisibilityCommand}">
                                    <MenuItem.CommandParameter>
                                        <enums:VisibilityType>Public</enums:VisibilityType>
                                    </MenuItem.CommandParameter>
                                </MenuItem>
                                <MenuItem Header="{DynamicResource FriendsOnly}"
                                          Command="{Binding SetSelectedVisibilityCommand}">
                                    <MenuItem.CommandParameter>
                                        <enums:VisibilityType>FriendsOnly</enums:VisibilityType>
                                    </MenuItem.CommandParameter>
                                </MenuItem>
                                <MenuItem Header="{DynamicResource Private}"
                                          Command="{Binding SetSelectedVisibilityCommand}">
                                    <MenuItem.CommandParameter>
                                        <enums:VisibilityType>Private</enums:VisibilityType>
                                    </MenuItem.CommandParameter>
                                </MenuItem>
                                <MenuItem Header="{DynamicResource Unlisted}"
                                          Command="{Binding SetSelectedVisibilityCommand}">
                                    <MenuItem.CommandParameter>
                                        <enums:VisibilityType>Unlisted</enums:VisibilityType>
                                    </MenuItem.CommandParameter>
                                </MenuItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button Classes="action"
                            Command="{Binding RequestBulkDeleteCommand}"
                            IsEnabled="{Binding HasSelection}"
                            Foreground="{DynamicResource FeedbackDangerTextBrush}"
                            BorderBrush="{DynamicResource FeedbackDangerBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <icons:MaterialIcon Kind="TrashCanOutline" Width="14" Height="14"/>
                            <TextBlock Text="{DynamicResource DeleteSelected}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="action"
                            Command="{Binding ExitSelectionModeCommand}"
                            Content="{DynamicResource Cancel}"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="32,0,32,40">

            <!-- Loading -->
            <StackPanel IsVisible="{Binding IsLoading}"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Spacing="14">
                <ProgressBar IsIndeterminate="True" Width="220" Height="3"
                             Background="{DynamicResource SurfaceCardBrush}"
                             Foreground="{DynamicResource AccentPrimaryBrush}"/>
                <TextBlock Text="{DynamicResource LoadingPublications}"
                           HorizontalAlignment="Center"
                           FontSize="13"
                           Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>

            <!-- Error -->
            <Border IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Background="{DynamicResource SurfaceCardBrush}"
                    BorderBrush="{DynamicResource FeedbackDangerBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14"
                    VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <icons:MaterialIcon Kind="AlertCircleOutline"
                                        Width="20" Height="20"
                                        Foreground="{DynamicResource FeedbackDangerBrush}"
                                        VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Empty -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="!IsLoading"/>
                        <Binding Path="HasNoItems"/>
                    </MultiBinding>
                </StackPanel.IsVisible>
                <icons:MaterialIcon Kind="PackageVariantClosed"
                                    Width="56" Height="56"
                                    Foreground="{DynamicResource TextDisabledBrush}"
                                    HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource NoPublications}"
                           FontSize="15"
                           Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Grid -->
            <ScrollViewer IsVisible="{Binding !IsLoading}">
                <ItemsControl ItemsSource="{Binding FilteredItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:WorkshopItem">
                            <Button Classes="mod-card"
                                    Classes.selected="{Binding IsSelected}"
                                    Command="{Binding $parent[ItemsControl].((vm:ItemListViewModel)DataContext).SelectItemCommand, FallbackValue={x:Null}}"
                                    CommandParameter="{Binding}"
                                    Width="220"
                                    Margin="0,0,14,14">
                                <StackPanel>
                                    <!-- Thumbnail -->
                                    <Border Height="124"
                                            Background="{DynamicResource SurfaceCardBrush}"
                                            ClipToBounds="True"
                                            CornerRadius="10,10,0,0">
                                        <Panel>
                                            <Image Source="{Binding PreviewBitmap}" Stretch="UniformToFill"
                                                   IsVisible="{Binding PreviewBitmap, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                            <icons:MaterialIcon Kind="ImageOutline"
                                                                Width="28" Height="28"
                                                                Foreground="{DynamicResource TextDisabledBrush}"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                IsVisible="{Binding PreviewBitmap, Converter={x:Static ObjectConverters.IsNull}}"/>

                                            <!-- Selection check overlay — only paints in selection mode.
                                                 The card button itself toggles IsSelected, the visual is
                                                 read-only here. -->
                                            <Border Classes="select-check"
                                                    Classes.checked="{Binding IsSelected}"
                                                    IsVisible="{Binding $parent[ItemsControl].((vm:ItemListViewModel)DataContext).SelectionMode, FallbackValue=False}">
                                                <icons:MaterialIcon Kind="Check"
                                                                    Width="16" Height="16"
                                                                    Foreground="White"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    IsVisible="{Binding IsSelected}"/>
                                            </Border>

                                            <!-- Badges row (contributor + visibility) -->
                                            <StackPanel Orientation="Horizontal" Spacing="6"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Margin="0,8,8,0">
                                                <!-- Contributor — only when the user isn't the owner -->
                                                <Border Classes="contributor-badge"
                                                        IsVisible="{Binding !IsOwner}"
                                                        ToolTip.Tip="{DynamicResource Contributor}">
                                                    <icons:MaterialIcon Kind="HandshakeOutline"
                                                                        Width="13" Height="13"
                                                                        VerticalAlignment="Center"
                                                                        HorizontalAlignment="Center"/>
                                                </Border>

                                                <!-- Visibility badge -->
                                                <Border Classes="vis-badge"
                                                        Classes.public="{Binding IsVisibilityPublic}"
                                                        Classes.friends="{Binding IsVisibilityFriends}"
                                                        Classes.private="{Binding IsVisibilityPrivate}"
                                                        Classes.unlisted="{Binding IsVisibilityUnlisted}">
                                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                        <icons:MaterialIcon Width="11" Height="11" VerticalAlignment="Center"
                                                                            Kind="Eye"
                                                                            IsVisible="{Binding IsVisibilityPublic}"/>
                                                        <icons:MaterialIcon Width="11" Height="11" VerticalAlignment="Center"
                                                                            Kind="AccountGroup"
                                                                            IsVisible="{Binding IsVisibilityFriends}"/>
                                                        <icons:MaterialIcon Width="11" Height="11" VerticalAlignment="Center"
                                                                            Kind="Lock"
                                                                            IsVisible="{Binding IsVisibilityPrivate}"/>
                                                        <icons:MaterialIcon Width="11" Height="11" VerticalAlignment="Center"
                                                                            Kind="EyeOff"
                                                                            IsVisible="{Binding IsVisibilityUnlisted}"/>
                                                        <TextBlock Text="{DynamicResource Public}" FontSize="11" FontWeight="Medium"
                                                                   VerticalAlignment="Center"
                                                                   IsVisible="{Binding IsVisibilityPublic}"/>
                                                        <TextBlock Text="{DynamicResource FriendsOnly}" FontSize="11" FontWeight="Medium"
                                                                   VerticalAlignment="Center"
                                                                   IsVisible="{Binding IsVisibilityFriends}"/>
                                                        <TextBlock Text="{DynamicResource Private}" FontSize="11" FontWeight="Medium"
                                                                   VerticalAlignment="Center"
                                                                   IsVisible="{Binding IsVisibilityPrivate}"/>
                                                        <TextBlock Text="{DynamicResource Unlisted}" FontSize="11" FontWeight="Medium"
                                                                   VerticalAlignment="Center"
                                                                   IsVisible="{Binding IsVisibilityUnlisted}"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Panel>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Margin="12,10" Spacing="4">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="13"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding SubscribersDisplay, StringFormat='{}{0} subs'}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}"/>
                                            <TextBlock Text="·"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextDisabledBrush}"/>
                                            <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:dd MMM yyyy}'}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>

        <!-- Bulk delete confirmation overlay — same type-DELETE gate as the
             single-mod path so the destructive action stays explicit. -->
        <Border Grid.RowSpan="2"
                IsVisible="{Binding ShowBulkDeleteConfirmation}"
                Background="#CC000000">
            <Border Background="{DynamicResource SurfaceOverlayBrush}"
                    Padding="28" CornerRadius="12"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="420">
                <StackPanel Spacing="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding SelectedCount, StringFormat={}Delete {0} mods?}"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{DynamicResource BulkDeleteWarning}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="13"/>
                    </StackPanel>
                    <Border Background="#1FC23B2E" Padding="12" CornerRadius="6"
                            BorderBrush="{DynamicResource FeedbackDangerBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <icons:MaterialIcon Kind="AlertCircleOutline" Width="14" Height="14"
                                                Foreground="{DynamicResource FeedbackDangerTextBrush}"
                                                VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource DeleteWarning}"
                                       Foreground="{DynamicResource FeedbackDangerTextBrush}"
                                       FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <StackPanel Spacing="6">
                        <TextBlock Text="{DynamicResource DeleteTypeToConfirm}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13"/>
                        <TextBox Text="{Binding BulkDeleteTypedConfirmation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="DELETE"
                                 FontFamily="Consolas, Menlo, monospace"
                                 IsEnabled="{Binding !IsBulkProcessing}"/>
                        <TextBlock Text="{DynamicResource DeleteTypeToConfirmHint}"
                                   Foreground="{DynamicResource TextDisabledBrush}"
                                   FontSize="11"
                                   IsVisible="{Binding !IsBulkDeleteConfirmed}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                        <Button Command="{Binding CancelBulkDeleteCommand}"
                                Classes="action"
                                Content="{DynamicResource Cancel}"
                                IsEnabled="{Binding !IsBulkProcessing}"/>
                        <Button Command="{Binding ConfirmBulkDeleteCommand}"
                                Background="{DynamicResource FeedbackDangerBrush}"
                                Foreground="White"
                                CornerRadius="6"
                                Padding="14,0"
                                Height="34"
                                FontWeight="Medium"
                                FontSize="13"
                                Content="{DynamicResource DeletePermanently}"
                                IsEnabled="{Binding IsBulkDeleteConfirmed}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>