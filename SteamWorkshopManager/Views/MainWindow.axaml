<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SteamWorkshopManager.ViewModels"
        xmlns:shell="using:SteamWorkshopManager.Views.Shell"
        xmlns:local="using:SteamWorkshopManager"
        xmlns:helpers="using:SteamWorkshopManager.Helpers"
        xmlns:icons="using:Material.Icons.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="SteamWorkshopManager.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}"
        MinWidth="900" MinHeight="600"
        Width="1100" Height="750"
        Background="{DynamicResource WindowBackgroundBrush}"
        DragDrop.AllowDrop="True">

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Panel>
        <Grid RowDefinitions="Auto,Auto,*,Auto">

            <!-- Top bar (Raycast-style nav shell) -->
            <shell:TopBarView Grid.Row="0"/>

            <!-- Update banner -->
            <Border Grid.Row="1"
                    IsVisible="{Binding IsUpdateAvailable}"
                    Background="{DynamicResource SurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource UpdateAvailable}"
                                   Foreground="{DynamicResource AccentSecondaryBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding UpdateInfo.LatestVersion}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Command="{Binding OpenReleasePageCommand}"
                            Classes="accent"
                            Padding="12,6"
                            FontSize="12">
                        <TextBlock Text="{DynamicResource Download}"/>
                    </Button>
                    <Button Grid.Column="2"
                            Command="{Binding DismissUpdateCommand}"
                            Classes="ghost"
                            Padding="8,4"
                            Margin="8,0,0,0"
                            FontSize="14"
                            Content="✕"/>
                </Grid>
            </Border>

            <!-- Main content (transparent so the window gradient shows through).
                 Two animation layers coexist:
                   · PageTransition — plays when Content swaps (tab navigation).
                   · Transitions on Opacity + RenderTransform — plays on session
                     switch (Content is unchanged but the underlying data is
                     reloading), driven by the Classes.switching binding below.
                 When IsSwitchingSession goes false → the class is removed,
                 RenderTransform animates from translateY(-24) back to 0 and
                 Opacity from 0 back to 1 — the "ghost descending" effect. -->
            <TransitioningContentControl Grid.Row="2"
                                         Name="ShellContent"
                                         Classes.switching="{Binding IsSwitchingSession}"
                                         Content="{Binding CurrentView}"
                                         DragDrop.AllowDrop="True">
                <TransitioningContentControl.Styles>
                    <Style Selector="TransitioningContentControl#ShellContent">
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="RenderTransform" Value="none"/>
                        <Setter Property="Transitions">
                            <Transitions>
                                <DoubleTransition Property="Opacity"
                                                  Duration="0:0:0.35"
                                                  Easing="CubicEaseOut"/>
                                <TransformOperationsTransition Property="RenderTransform"
                                                               Duration="0:0:0.35"
                                                               Easing="CubicEaseOut"/>
                            </Transitions>
                        </Setter>
                    </Style>
                    <Style Selector="TransitioningContentControl#ShellContent.switching">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="RenderTransform" Value="translateY(-24px)"/>
                    </Style>
                </TransitioningContentControl.Styles>
                <TransitioningContentControl.PageTransition>
                    <CompositePageTransition>
                        <PageSlide Duration="0:0:0.25" Orientation="Vertical"/>
                        <CrossFade Duration="0:0:0.2"/>
                    </CompositePageTransition>
                </TransitioningContentControl.PageTransition>
            </TransitioningContentControl>

            <!-- Footer: Steam connection indicator + app version -->
            <shell:FooterView Grid.Row="3"/>

        </Grid>

        <!-- Upload progress toast -->
        <Border IsVisible="{Binding IsUploadInProgress}"
                Background="#F0242a35"
                CornerRadius="12"
                Padding="20,16"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,24,24"
                MinWidth="320"
                BoxShadow="{DynamicResource ShadowOverlay}">
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border Width="32" Height="32" CornerRadius="16"
                            Background="{DynamicResource AccentPrimaryGradientBrush}">
                        <TextBlock Text="↑" FontSize="16" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding UploadStatusMessage}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                        <TextBlock Text="{Binding UploadProgressText}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>
                <ProgressBar Value="{Binding UploadProgress}"
                             Minimum="0"
                             Maximum="100"
                             Height="4"
                             CornerRadius="2"
                             Background="{DynamicResource BorderStrongBrush}"
                             Foreground="{DynamicResource AccentPrimaryGradientBrush}"/>
            </StackPanel>
        </Border>

        <!-- Success toast -->
        <Border IsVisible="{Binding IsSuccessNotification}"
                Background="#F01e3a1e"
                CornerRadius="12"
                Padding="20,16"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,24,0,0"
                MinWidth="300"
                BoxShadow="{DynamicResource ShadowOverlay}">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border Width="32" Height="32" CornerRadius="16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#4CAF50" Offset="0"/>
                            <GradientStop Color="#81C784" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="✓" FontSize="18" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{Binding NotificationMessage}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold"
                           FontSize="14"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Error toast -->
        <Border IsVisible="{Binding IsErrorNotification}"
                Background="#F03d1e1e"
                CornerRadius="12"
                Padding="20,16"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,24,0,0"
                MinWidth="300"
                BoxShadow="{DynamicResource ShadowOverlay}">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border Width="32" Height="32" CornerRadius="16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#f44336" Offset="0"/>
                            <GradientStop Color="#e57373" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="✗" FontSize="18" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{Binding NotificationMessage}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold"
                           FontSize="14"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Delete-session confirmation modal: same type-to-confirm pattern
             as the per-mod delete in ItemEditorView. -->
        <Border IsVisible="{Binding ShowDeleteSessionConfirmation}"
                Background="#CC0E141B"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border MaxWidth="520"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource SurfaceCardBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24"
                    BoxShadow="{DynamicResource ShadowOverlay}">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <icons:MaterialIcon Kind="AlertOctagonOutline"
                                            Width="22" Height="22"
                                            Foreground="{DynamicResource FeedbackDangerTextBrush}"
                                            VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource DeleteSessionTitle}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{Binding DeleteSessionIntroText}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13"/>

                    <StackPanel Spacing="6" Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <icons:MaterialIcon Kind="CircleSmall" Width="14" Height="14"
                                                Foreground="{DynamicResource TextMutedBrush}"
                                                VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource DeleteSessionItemSession}"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding SessionDeleteReport.HasCache}">
                            <icons:MaterialIcon Kind="CircleSmall" Width="14" Height="14"
                                                Foreground="{DynamicResource TextMutedBrush}"
                                                VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource DeleteSessionItemCache}"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding SessionDeleteReport.HasDownloads}">
                            <icons:MaterialIcon Kind="CircleSmall" Width="14" Height="14"
                                                Foreground="{DynamicResource TextMutedBrush}"
                                                VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DeleteSessionDownloadsText}"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding SessionDeleteReport.HasDrafts}">
                            <icons:MaterialIcon Kind="CircleSmall" Width="14" Height="14"
                                                Foreground="{DynamicResource TextMutedBrush}"
                                                VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DeleteSessionDraftsText}"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="{Binding DeleteSessionTotalText}"
                               FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}"/>

                    <Border Background="#1F5B9CF6" Padding="10" CornerRadius="6"
                            BorderBrush="{DynamicResource AccentPrimaryBrush}" BorderThickness="1"
                            IsVisible="{Binding SessionDeleteReport.AppIdSharedWithOtherSession}">
                        <TextBlock Text="{DynamicResource DeleteSessionSharedAppId}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Border>

                    <Border Background="#1FE0A24A" Padding="10" CornerRadius="6"
                            BorderBrush="{DynamicResource FeedbackWarningBrush}" BorderThickness="1">
                        <TextBlock Text="{DynamicResource DeleteSessionFinalWarning}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Border>

                    <StackPanel Spacing="6">
                        <TextBlock Text="{DynamicResource DeleteTypeToConfirm}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBox Text="{Binding DeleteSessionTypedConfirmation}"
                                 PlaceholderText="{x:Static helpers:DangerousActions.ConfirmationPassphrase}"
                                 FontFamily="Consolas,Menlo,monospace"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Command="{Binding CancelDeleteSessionCommand}"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Padding="14,8"
                                CornerRadius="6">
                            <TextBlock Text="{DynamicResource Cancel}"/>
                        </Button>
                        <Button Command="{Binding ConfirmDeleteSessionCommand}"
                                IsEnabled="{Binding IsDeleteSessionConfirmed}"
                                Background="{DynamicResource FeedbackDangerBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="14,8"
                                CornerRadius="6"
                                FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <icons:MaterialIcon Kind="TrashCanOutline" Width="14" Height="14"/>
                                <TextBlock Text="{DynamicResource DeletePermanently}"
                                           IsVisible="{Binding !IsDeletingSession}"/>
                                <TextBlock Text="..."
                                           IsVisible="{Binding IsDeletingSession}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Session switch overlay -->
        <Border IsVisible="{Binding IsSwitchingSession}"
                Background="#CC0E141B"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="20"
                        Width="280">
                <ProgressBar IsIndeterminate="True"
                             Height="4"
                             CornerRadius="2"
                             Background="{DynamicResource SurfaceElevatedBrush}"
                             Foreground="{DynamicResource AccentPrimaryBrush}"/>
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock Text="{DynamicResource SwitchingSession}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ActiveGameName}"
                               FontSize="13"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Panel>
</Window>
